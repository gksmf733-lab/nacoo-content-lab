# Vercel Postgres (Neon) — vercel env pull .env.local 로 자동 채워짐
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# 웹사이트 로그인 비밀번호 (본인만 사용)
SITE_PASSWORD=choose-a-strong-password

# 로그인 쿠키 서명용 비밀값 (아무 랜덤 문자열)
AUTH_SECRET=generate-with-openssl-rand-hex-32

# 자동화 에이전트가 POST /api/notices, /api/scripts 호출 시 사용하는 Bearer 토큰
API_TOKEN=another-random-token

# Vercel Cron 호출 시 사용하는 Bearer 토큰 (Vercel 대시보드에서 설정)
CRON_SECRET=vercel-cron-secret

# 로그아웃 리다이렉트용 (프로덕션에선 https://naku-lab.vercel.app 등)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
